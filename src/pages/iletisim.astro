---
import Layout from '../layouts/Layout.astro';
---

<Layout title="İletişim" activePage="iletisim">
  <div class="page-hero"><h1>İletişim</h1><p>Bize ulaşın</p></div>
  <section class="section">
    <div class="section-inner">
      <div class="contact-grid">
        <div class="contact-info">
          <h3>İletişim Bilgileri</h3>
          <div class="contact-item">
            <div class="contact-icon"><svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg></div>
            <div class="contact-detail"><strong>Adres</strong>Hadımköy Mah. Atatürk Sanayi Bölgesi,<br>Hamit Kaplan Sokak No:12<br>34555, Arnavutköy, İstanbul, Türkiye</div>
          </div>
          <div class="contact-item">
            <div class="contact-icon"><svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg></div>
            <div class="contact-detail"><strong>Email</strong><a href="mailto:satis@yenipak.com">satis@yenipak.com</a><br><a href="mailto:info@yenipak.com">info@yenipak.com</a></div>
          </div>
          <div class="contact-item">
            <div class="contact-icon"><svg viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.15 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg></div>
            <div class="contact-detail"><strong>Telefon & Faks</strong><a href="tel:+902127714774">T: +90 212 771 47 74 (pbx)</a><br>F: +90 212 771 06 04</div>
          </div>
          <div class="map-container">
            <iframe src="https://maps.google.com/maps?q=Hadımköy+Mah.+Atatürk+Sanayi+Bölgesi,+Hamit+Kaplan+Sokak+No:12+Arnavutköy+İstanbul&output=embed" allowfullscreen loading="lazy"></iframe>
          </div>
        </div>
        <div class="contact-form-box">
          <h3>Mesaj Gönderin</h3>
          <form id="contact-form">
            <div class="form-row">
              <div class="form-field"><label>Adınız</label><input type="text" name="firstname" placeholder="Adınız" required></div>
              <div class="form-field"><label>Soyadınız</label><input type="text" name="lastname" placeholder="Soyadınız" required></div>
            </div>
            <div class="form-field"><label>Email</label><input type="email" name="email" placeholder="email@sirket.com" required></div>
            <div class="form-field"><label>Mesajınız</label><textarea name="message" rows="5" placeholder="Mesajınızı buraya yazın..." required></textarea></div>
            <button type="submit" class="btn-primary" style="width:100%;text-align:center">Gönder</button>
          </form>
          <div class="success-msg" id="contact-success">&#10003; Mesajınız için teşekkürler! En kısa sürede dönüş yapacağız.</div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; }
  .contact-info h3 { font-family: 'Montserrat', sans-serif; font-size: 18px; font-weight: 700; color: var(--blue-dark); margin-bottom: 24px; }
  .contact-item { display: flex; gap: 14px; margin-bottom: 20px; align-items: flex-start; }
  .contact-icon { width: 40px; height: 40px; background: var(--blue); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .contact-icon svg { fill: white; width: 18px; height: 18px; }
  .contact-detail { font-size: 14px; color: var(--text-light); line-height: 1.8; }
  .contact-detail strong { display: block; font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 2px; }
  .contact-detail a { color: var(--blue); text-decoration: none; }
  .contact-form-box { background: var(--gray-bg); border-radius: 12px; padding: 36px; }
  .contact-form-box h3 { font-family: 'Montserrat', sans-serif; font-size: 18px; font-weight: 700; color: var(--blue-dark); margin-bottom: 24px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
  .form-field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
  .form-field label { font-size: 12px; font-weight: 600; font-family: 'Montserrat', sans-serif; color: var(--text); }
  .form-field input, .form-field textarea { padding: 10px 14px; border: 1px solid var(--border); border-radius: 5px; font-family: 'Open Sans', sans-serif; font-size: 13.5px; outline: none; background: var(--white); transition: border .2s; resize: vertical; }
  .form-field input:focus, .form-field textarea:focus { border-color: var(--blue); }
  .success-msg { display: none; background: #d4edda; color: #155724; border-radius: 6px; padding: 12px 16px; font-size: 13px; margin-top: 12px; }
  .map-container { border-radius: 12px; overflow: hidden; margin-top: 32px; box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
  .map-container iframe { width: 100%; height: 300px; border: none; display: block; }

  @media (max-width: 1000px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const data = new FormData(form);
    const body = encodeURIComponent(
      'Gönderen: ' + data.get('firstname') + ' ' + data.get('lastname') +
      '\nEmail: ' + data.get('email') +
      '\n\nMesaj:\n' + data.get('message')
    );
    window.location.href = 'mailto:satis@yenipak.com?subject=Web%20Sitesi%20%C4%B0leti%C5%9Fim%20Formu&body=' + body;
    document.getElementById('contact-success')!.style.display = 'block';
  });
</script>
